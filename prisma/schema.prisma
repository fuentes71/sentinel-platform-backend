generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String   @default("user") // admin | user
  createdAt    DateTime @default(now())
}

model Asset {
  id         String   @id @default(uuid())
  name       String
  status     String   @default("online")
  lastUpdate DateTime @default(now())

  events     Event[]
  alerts     Alert[]
  rules      Rule[]
}

model Event {
  id        String   @id @default(uuid())
  assetId   String
  type      String   // status | metric | system
  value     String   // Storing number or string as string, parsed on demand
  timestamp DateTime @default(now())

  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model Alert {
  id         String   @id @default(uuid())
  assetId    String
  level      String   // info | warning | critical
  message    String
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  resolvedAt DateTime?
  resolvedBy String?

  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model Rule {
  id        String   @id @default(uuid())
  assetId   String?  // Can be null if global
  condition String   // > | < | =
  threshold Float
  level     String   // medium | strong
  enabled   Boolean  @default(true)

  asset     Asset?   @relation(fields: [assetId], references: [id], onDelete: Cascade)
}
